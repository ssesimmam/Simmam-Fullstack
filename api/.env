# Optional Redis / Upstash settings (recommended for production)
# Example Redis URL: REDIS_URL=redis://:password@redis-host:6379
# Example Upstash (REST): UPSTASH_REDIS_REST_URL=https://us1-upstash.example
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token
# When set to true, prefers Redis/Upstash for caching and avoids unbounded memory fallback
# CACHE_PREFER_REDIS=true
# Prefix for cache keys stored in Redis
# REDIS_CACHE_PREFIX=cache:
# Bounds for in-memory fallbacks (only used when Redis/Upstash unavailable)
# MAX_MEMORY_CACHE_ENTRIES=1000
# MAX_MEMORY_RATE_LIMIT_KEYS=10000

# Set NODE_ENV=production in production deployments
# NODE_ENV=production

# Observability and production tuning (optional)
# Milliseconds above which a request is considered 'slow' and logged
# SLOW_REQUEST_MS=1000
# RSS memory (bytes) threshold to emit warnings
# MEMORY_WARNING_BYTES=734003200 # ~700MB
